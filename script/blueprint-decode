#!/usr/bin/env python3
"""blueprint-decode — decode a Factorio blueprint string to minified JSON.

Usage:
    blueprint-decode blueprint.bp
    blueprint-decode dir/           # recurse, writes .bp -> .json in-place
    echo '<blueprint string>' | blueprint-decode
"""

import argparse
import base64
import json
import os
import sys
import zlib


def decode_blueprint(raw: str) -> dict:
    """Decode a Factorio blueprint string to a Python dict.

    Factorio blueprint format:
      - First character is a version byte (e.g. '0')
      - Remainder is base64-encoded zlib-compressed JSON
    """
    raw = raw.strip()

    if not raw:
        raise ValueError("empty input")

    if not raw[0].isdigit():
        raise ValueError(f"unexpected version character '{raw[0]}'")

    b64_payload = raw[1:]

    try:
        compressed = base64.b64decode(b64_payload)
    except Exception as e:
        raise ValueError(f"base64 decode failed: {e}") from e

    try:
        decompressed = zlib.decompress(compressed)
    except zlib.error as e:
        raise ValueError(f"zlib decompress failed: {e}") from e

    try:
        return json.loads(decompressed)
    except json.JSONDecodeError as e:
        raise ValueError(f"JSON parse failed: {e}") from e


def decode_file(path: str) -> bool:
    """Decode a .bp file and write <stem>.json beside it. Returns True on success."""
    out_path = os.path.splitext(path)[0] + ".json"
    try:
        with open(path) as f:
            raw = f.read()
    except OSError as e:
        print(f"blueprint-decode: error reading {path}: {e}", file=sys.stderr)
        return False
    try:
        obj = decode_blueprint(raw)
    except ValueError as e:
        print(f"blueprint-decode: error: {path}: {e}", file=sys.stderr)
        return False
    with open(out_path, "w") as f:
        json.dump(obj, f, indent=None, ensure_ascii=False)
    print(out_path)
    return True


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Decode Factorio blueprint string(s) to JSON.",
        epilog=(
            "Pass a .bp file to write <file>.json beside it. "
            "Pass a directory to recurse over all *.bp files. "
            "Reads from stdin and prints to stdout if no argument is given."
        ),
    )
    parser.add_argument(
        "path",
        nargs="?",
        default=None,
        help="Blueprint file (.bp) or directory to process recursively",
    )
    args = parser.parse_args()

    if args.path is None:
        # stdin → stdout
        if sys.stdin.isatty():
            parser.print_help(sys.stderr)
            return 1
        raw = sys.stdin.read()
        try:
            obj = decode_blueprint(raw)
        except ValueError as e:
            print(f"blueprint-decode: error: {e}", file=sys.stderr)
            return 1
        print(json.dumps(obj, indent=None, ensure_ascii=False))
        return 0

    if os.path.isdir(args.path):
        errors = 0
        for dirpath, _, filenames in os.walk(args.path):
            for name in filenames:
                if name.endswith(".bp"):
                    if not decode_file(os.path.join(dirpath, name)):
                        errors += 1
        return 1 if errors else 0

    if not os.path.exists(args.path):
        print(f"blueprint-decode: error: not found: {args.path}", file=sys.stderr)
        return 1

    return 0 if decode_file(args.path) else 1


if __name__ == "__main__":
    sys.exit(main())
